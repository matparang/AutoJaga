SWARM MANAGER INTEGRATION

```python
# jagabot/swarm/subagent_manager.py (new)

class SubagentManager:
    """Manages stateless subagent execution"""
    
    def __init__(self):
        self.pool = ProcessPoolExecutor(max_workers=4)
        self.prompts = self.load_prompts()
    
    def load_prompts(self):
        """Load subagent prompts from files"""
        return {
            'websearch': Path('jagabot/subagents/prompts/websearch_subagent.md').read_text(),
            'tools': Path('jagabot/subagents/prompts/tools_subagent.md').read_text(),
            'models': Path('jagabot/subagents/prompts/models_subagent.md').read_text(),
            'reasoning': Path('jagabot/subagents/prompts/reasoning_subagent.md').read_text()
        }
    
    def execute_workflow(self, skill_name, data):
        """Execute 4-subagent workflow with dependencies"""
        
        # Stage 1: WebSearch (no dependencies)
        web_future = self.pool.submit(
            self.run_subagent,
            'websearch',
            self.prompts['websearch'],
            data
        )
        web_result = web_future.result(timeout=30)
        
        if not web_result.get('success', True):
            return {'error': 'WebSearch failed', 'details': web_result}
        
        # Stage 2: Tools (depends on web_result)
        tools_future = self.pool.submit(
            self.run_subagent,
            'tools',
            self.prompts['tools'],
            {**data, 'prices': web_result['prices'], 'history': web_result.get('history', [])}
        )
        tools_result = tools_future.result(timeout=30)
        
        # Stage 3: Models (depends on web + tools)
        models_future = self.pool.submit(
            self.run_subagent,
            'models',
            self.prompts['models'],
            {**data, **web_result, **tools_result}
        )
        models_result = models_future.result(timeout=30)
        
        # Stage 4: Reasoning (depends on all previous)
        reasoning_future = self.pool.submit(
            self.run_subagent,
            'reasoning',
            self.prompts['reasoning'],
            {**data, **web_result, **tools_result, **models_result}
        )
        reasoning_result = reasoning_future.result(timeout=30)
        
        return {
            'web': web_result,
            'tools': tools_result,
            'models': models_result,
            'reasoning': reasoning_result
        }
    
    def run_subagent(self, agent_type, prompt, data):
        """Run a single subagent (stateless)"""
        # Execute in sandbox
        result = sandbox.execute(
            agent_type=agent_type,
            system_prompt=prompt,
            user_data=data
        )
        # Subagent dies here - no state preserved
        return result
```

