"""
AutoJaga API Server - REST API for CoPaw integration

Provides HTTP endpoints for:
- Experiment planning (AutoJaga research pipeline)
- Results analysis
- Tool execution

Usage:
    python3 -m jagabot.api.server
    # or
    uvicorn jagabot.api.server:app --host 0.0.0.0 --port 8000
"""

import os
import sys
import json
from pathlib import Path
from datetime import datetime
from typing import Dict, Any, Optional, List

from fastapi import FastAPI, HTTPException, BackgroundTasks
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel, Field
import uvicorn

# Import for agent bridge
import asyncio
from jagabot.bus.queue import MessageBus
from jagabot.bus.events import InboundMessage
from jagabot.agent.loop import AgentLoop

# ── Global agent state ────────────────────────────────────────
# Single agent instance shared across all requests
_agent_bus: MessageBus = None
_agent_loop_task: asyncio.Task = None
_agent_instance: AgentLoop = None

# Add parent directory to path
sys.path.insert(0, str(Path(__file__).parent.parent.parent))

from loguru import logger

# ── Agent Bridge Functions ────────────────────────────────────────
app = FastAPI(
    title="AutoJaga API",
    description="REST API for AutoJaga research and analysis",
    version="5.0.0",
    docs_url="/docs",
    redoc_url="/redoc"
)

# ── New /execute endpoint ────────────────────────────────────────

        logger.info(f"Agent completed task (session: {session_id})")

        return {
            "status": "success",
            "session_id": session_id,
            "response": response.content,
            "tools_used": getattr(response, "tools_used", []),
        }

    except asyncio.TimeoutError:
        logger.error(f"Agent timeout (session: {session_id})")
        return {
            "status": "timeout",
            "session_id": session_id,
            "message": "Agent exceeded 5 minute limit"
        }
    except Exception as e:
        logger.error(f"Agent execution error: {e}")
        import traceback
        traceback.print_exc()
        return {
            "status": "error",
            "message": str(e)
        }

# Enable CORS for CoPaw and other clients
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],  # In production, specify exact origins
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Workspace configuration
WORKSPACE = Path(os.getenv("AUTOJAGA_WORKSPACE", Path.home() / ".jagabot" / "workspace"))
WORKSPACE.mkdir(parents=True, exist_ok=True)

# Session tracking
active_sessions: Dict[str, Dict[str, Any]] = {}


# ============================================================================
# Request/Response Models
# ============================================================================

class PlanRequest(BaseModel):
    """Request for experiment planning"""
    prompt: str = Field(..., description="Research topic or experiment objective")
    context: Dict[str, Any] = Field(default_factory=dict, description="Additional context")
    previous_results: Optional[Dict[str, Any]] = Field(default=None, description="Previous experiment results")
    depth: str = Field(default="comprehensive", enum=["basic", "comprehensive"], description="Research depth")


class PlanResponse(BaseModel):
    """Response from experiment planning"""
    status: str
    blueprint: str
    metrics: Dict[str, Any]
    session_id: str
    timestamp: str


class AnalyzeRequest(BaseModel):
    """Request for results analysis"""
    experiment_data: Dict[str, Any] = Field(..., description="Current experiment results")
    previous_results: Optional[Dict[str, Any]] = Field(default=None, description="Historical results")
    experiment_num: Optional[int] = Field(default=None, description="Experiment number")


class AnalyzeResponse(BaseModel):
    """Response from results analysis"""
    status: str
    analysis: str
    recommendation: str
    improvement: Optional[str]
    next_prompt: str
    session_id: str


class ToolExecuteRequest(BaseModel):
    """Request for tool execution"""
    tool_name: str = Field(..., description="Name of tool to execute")
    parameters: Dict[str, Any] = Field(default_factory=dict, description="Tool parameters")


class ToolExecuteResponse(BaseModel):
    """Response from tool execution"""
    status: str
    result: Any
    execution_time_ms: float


class HealthResponse(BaseModel):
    """Health check response"""
    status: str
    version: str
    workspace: str
    timestamp: str
    active_sessions: int


# ============================================================================
# API Endpoints
# ============================================================================

@app.get("/", tags=["Root"])
async def root():
    """Root endpoint - API information"""
    return {
        "name": "AutoJaga API",
        "version": "5.0.0",
        "description": "REST API for AutoJaga research and analysis",
        "docs": "/docs",
        "health": "/health"
    }


@app.get("/health", response_model=HealthResponse, tags=["Health"])
async def health_check():
    """Health check endpoint"""
    return HealthResponse(
        status="healthy",
        version="5.0.0",
        workspace=str(WORKSPACE),
        timestamp=datetime.now().isoformat(),
        active_sessions=len(active_sessions)
    )


@app.post("/plan", response_model=PlanResponse, tags=["Research"])
async def create_plan(request: PlanRequest):
    """
    Create experiment blueprint using AutoJaga agent runtime.
    
    This endpoint:
    1. Starts a real Jagabot agent session
    2. Sends the prompt to the agent for processing
    3. Returns the agent's structured response
    
    **Example:**
    ```json
    {
        "prompt": "Improve logistic regression accuracy",
        "context": {"domain": "machine_learning"},
        "previous_results": {"accuracy": 0.86}
    }
    ```
    """
    logger.info(f"Creating plan for: {request.prompt[:100]}...")
    
    try:
        # Create session
        session_id = f"session_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
        active_sessions[session_id] = {
            "prompt": request.prompt,
            "created_at": datetime.now().isoformat(),
            "status": "processing"
        }
        
        # Try to use real Jagabot agent runtime
        try:
            from jagabot.agent.loop import AgentLoop
            from jagabot.bus.queue import MessageBus
            from jagabot.providers.litellm_provider import LiteLLMProvider
            from jagabot.config.schema import ExecToolConfig
            import asyncio
            
            logger.info("Starting real Jagabot agent session...")
            
            # Load existing Jagabot configuration
            config_path = Path.home() / ".jagabot" / "config.json"
            if config_path.exists():
                with open(config_path) as f:
                    config = json.load(f)
                logger.info(f"Loaded Jagabot config from {config_path}")
            else:
                config = {}
            
            # Get model from config (defaults to qwen-plus)
            model = config.get("agents", {}).get("defaults", {}).get("model", "dashscope/qwen-plus")
            logger.info(f"Using model: {model}")
            
            # Get DashScope API configuration
            dashscope_config = config.get("providers", {}).get("dashscope", {})
            api_key = dashscope_config.get("apiKey", "")
            api_base = dashscope_config.get("apiBase", None)
            
            if api_key:
                logger.info("Using DashScope API key from config")
            else:
                logger.warning("No DashScope API key found in config")
            
            # Create minimal agent setup with existing config
            bus = MessageBus()
            provider = LiteLLMProvider(
                api_key=api_key,
                api_base=api_base,
                default_model=model,
                provider_name="dashscope"
            )
            workspace = Path("/root/.jagabot/workspace")
            workspace.mkdir(parents=True, exist_ok=True)
            
            agent = AgentLoop(
                bus=bus,
                provider=provider,
                workspace=workspace,
                model=model,  # Use configured model
                max_iterations=10,  # Limit for API responses
            )
            
            # Create a task for the agent to process
            # We'll use a simplified approach - directly call LLM with tool context
            from blueprint_schema import create_blueprint, blueprint_to_dict, BLUEPRINTS
            
            # First, get LLM to analyze the prompt and select algorithm
            prompt_lower = request.prompt.lower()
            
            # Build system prompt for algorithm selection
            system_prompt = """You are an ML experiment planner. Based on the user's request, select the best algorithm.

Available algorithms:
1. RandomForestClassifier - Good for ensemble methods, non-linear patterns, general purpose
2. GradientBoostingClassifier - Improved accuracy, gradient boosting
3. XGBClassifier - Best performance, XGBoost
4. ExtraTreesClassifier - Reduced overfitting
5. SVC - Complex decision boundaries, SVM
6. KNeighborsClassifier - Simple, instance-based

Respond with ONLY the algorithm name from the list above.
If the user is asking a general question (not about ML experiments), respond with "GENERAL_QUESTION"."""

            user_prompt = f"Select best algorithm for: {request.prompt}"
            
            # Call LLM directly
            messages = [
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_prompt}
            ]
            
            response = await provider.chat(
                messages=messages,
                tools=[],
                model=model
            )
            
            selected_algo = response.content.strip() if response.content else "RandomForestClassifier"
            
            # Check if it's a general question
            if "GENERAL" in selected_algo.upper() or "QUESTION" in selected_algo.upper():
                # Handle general knowledge questions
                logger.info(f"Detected general question, providing explanation...")
                
                # Create a blueprint with explanation
                blueprint = BLUEPRINTS["random_forest"]()
                blueprint.rationale = f"General question detected. To answer '{request.prompt}', you would typically use financial analysis tools or web search. This blueprint provides a baseline ML experiment."
                
                # Add note that this is a general question
                blueprint_dict = blueprint_to_dict(blueprint)
                blueprint_dict["general_response"] = f"Note: '{request.prompt}' appears to be a general knowledge question. For accurate answers, use the talk command with web_search or financial analysis tools."
            else:
                # Map response to blueprint
                if "random" in selected_algo.lower() or "forest" in selected_algo.lower():
                    blueprint = BLUEPRINTS["random_forest"]()
                elif "gradient" in selected_algo.lower() or "boost" in selected_algo.lower():
                    blueprint = BLUEPRINTS["gradient_boosting"]()
                elif "xgb" in selected_algo.lower() or "xgboost" in selected_algo.lower():
                    blueprint = BLUEPRINTS["xgboost"]()
                elif "extra" in selected_algo.lower() or "trees" in selected_algo.lower():
                    blueprint = BLUEPRINTS["extra_trees"]()
                elif "svm" in selected_algo.lower() or "svc" in selected_algo.lower():
                    blueprint = create_blueprint(
                        algorithm_name="SVC",
                        forbidden_algorithms=["LogisticRegression"],
                        hyperparameters={"C": 1.0, "kernel": "rbf"},
                        rationale="SVM selected by agent"
                    )
                elif "knn" in selected_algo.lower() or "neighbors" in selected_algo.lower():
                    blueprint = create_blueprint(
                        algorithm_name="KNeighborsClassifier",
                        forbidden_algorithms=["LogisticRegression"],
                        hyperparameters={"n_neighbors": 5},
                        rationale="KNN selected by agent"
                    )
                else:
                    # Default to random forest for unknown responses
                    blueprint = BLUEPRINTS["random_forest"]()
                
                # Add agent analysis to rationale
                blueprint.rationale += f" (Selected by Jagabot agent: {selected_algo})"
                
                # Convert to dict
                blueprint_dict = blueprint_to_dict(blueprint)
            
            # Update session
            active_sessions[session_id]["status"] = "complete"
            active_sessions[session_id]["blueprint"] = blueprint_dict
            active_sessions[session_id]["agent_response"] = selected_algo
            
            logger.info(f"Plan created with real agent (session: {session_id}, algorithm: {blueprint.algorithm.name})")
            
            return PlanResponse(
                status="success",
                blueprint=json.dumps(blueprint_dict, indent=2),
                metrics={
                    "algorithm": blueprint.algorithm.name,
                    "rationale": blueprint.rationale,
                    "hyperparameters": blueprint.hyperparameters,
                    "agent_selected": selected_algo
                },
                session_id=session_id,
                timestamp=datetime.now().isoformat()
            )
            
        except ImportError as e:
            logger.warning(f"Jagabot agent runtime not available: {e}. Using fallback.")
            # Fallback to pre-defined blueprints
            from blueprint_schema import create_blueprint, blueprint_to_dict, BLUEPRINTS
            
            prompt_lower = request.prompt.lower()
            
            if "random" in prompt_lower or "forest" in prompt_lower or "ensemble" in prompt_lower:
                blueprint = BLUEPRINTS["random_forest"]()
                rationale = "Ensemble method selected for non-linear patterns"
            elif "gradient" in prompt_lower or "boost" in prompt_lower:
                blueprint = BLUEPRINTS["gradient_boosting"]()
                rationale = "Gradient boosting selected for improved accuracy"
            elif "xgboost" in prompt_lower or "xgb" in prompt_lower:
                blueprint = BLUEPRINTS["xgboost"]()
                rationale = "XGBoost selected for best performance"
            elif "extra" in prompt_lower or "trees" in prompt_lower:
                blueprint = BLUEPRINTS["extra_trees"]()
                rationale = "Extra Trees selected for reduced overfitting"
            else:
                blueprint = BLUEPRINTS["random_forest"]()
                rationale = "Random Forest selected as default robust algorithm"
            
            blueprint_dict = blueprint_to_dict(blueprint)
            
            active_sessions[session_id]["status"] = "complete"
            active_sessions[session_id]["blueprint"] = blueprint_dict
            
            logger.info(f"Plan created (fallback, session: {session_id})")
            
            return PlanResponse(
                status="success",
                blueprint=json.dumps(blueprint_dict, indent=2),
                metrics={
                    "algorithm": blueprint.algorithm.name,
                    "rationale": rationale,
                    "hyperparameters": blueprint.hyperparameters
                },
                session_id=session_id,
                timestamp=datetime.now().isoformat()
            )
        
    except Exception as e:
        logger.error(f"Plan creation failed: {e}")
        import traceback
        traceback.print_exc()
        raise HTTPException(status_code=500, detail=str(e))


@app.post("/analyze", response_model=AnalyzeResponse, tags=["Research"])
async def analyze_results(request: AnalyzeRequest):
    """
    Analyze experiment results and generate recommendations.
    
    This endpoint:
    1. Compares current results with previous
    2. Identifies patterns and insights
    3. Generates improvement recommendations
    4. Suggests next experiment
    
    **Example:**
    ```json
    {
        "experiment_data": {"accuracy": 0.88, "f1": 0.87},
        "previous_results": {"accuracy": 0.86, "f1": 0.85},
        "experiment_num": 2
    }
    ```
    """
    logger.info(f"Analyzing experiment {request.experiment_num} results...")
    
    try:
        # Create session
        session_id = f"analyze_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
        active_sessions[session_id] = {
            "type": "analysis",
            "experiment_num": request.experiment_num,
            "created_at": datetime.now().isoformat()
        }
        
        # Use AutoJaga evaluation tools
        try:
            from jagabot.agent.tools.evaluation import EvaluationKernel
            
            evaluator = EvaluationKernel()
            
            # Full evaluation
            evaluation = evaluator.full_evaluate(
                expected=request.previous_results or {},
                actual=request.experiment_data,
                history=[],
                execution_log=[]
            )
            
            # Generate analysis report
            analysis = _generate_analysis_report(
                request.experiment_data,
                request.previous_results,
                evaluation
            )
            
            # Extract improvement
            improvement = _extract_improvement(
                request.experiment_data,
                request.previous_results
            )
            
            # Generate next prompt
            next_prompt = _generate_next_prompt(
                request.experiment_data,
                request.previous_results,
                evaluation
            )
            
        except ImportError:
            logger.warning("EvaluationKernel not available, using fallback")
            analysis = _generate_fallback_analysis(request)
            improvement = "Unknown"
            next_prompt = "Continue optimization"
        
        # Update session
        active_sessions[session_id]["status"] = "complete"
        
        logger.info(f"Analysis complete (session: {session_id})")
        
        return AnalyzeResponse(
            status="success",
            analysis=analysis,
            recommendation=f"Try {next_prompt}",
            improvement=improvement,
            next_prompt=next_prompt,
            session_id=session_id
        )
        
    except Exception as e:
        logger.error(f"Analysis failed: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@app.post("/tools/execute", response_model=ToolExecuteResponse, tags=["Tools"])
async def execute_tool(request: ToolExecuteRequest):
    """
    Execute an AutoJaga tool directly.
    
    **Available Tools:**
    - financial_cv, monte_carlo, var, cvar
    - stress_test, correlation, recovery_time
    - k1_bayesian, k3_perspective, evaluate_result
    - And 35+ more...
    
    **Example:**
    ```json
    {
        "tool_name": "monte_carlo",
        "parameters": {
            "current_price": 100,
            "target_price": 120,
            "vix": 25
        }
    }
    ```
    """
    import time
    start_time = time.time()
    
    logger.info(f"Executing tool: {request.tool_name}")
    
    try:
        from jagabot.agent.tools.registry import ToolRegistry
        from jagabot.agent.tool_loader import register_default_tools
        
        registry = ToolRegistry()
        register_default_tools(
            registry,
            workspace=WORKSPACE,
            restrict_to_workspace=False,
            exec_config=None,
            brave_api_key=None,
            bus=None,
            subagents=None,
            cron_service=None,
        )
        
        tool = registry.get(request.tool_name)
        if not tool:
            raise HTTPException(status_code=404, detail=f"Tool '{request.tool_name}' not found")
        
        # Execute tool
        result = await tool.execute(**request.parameters)
        
        execution_time = (time.time() - start_time) * 1000
        
        logger.info(f"Tool {request.tool_name} executed in {execution_time:.2f}ms")
        
        return ToolExecuteResponse(
            status="success",
            result=result,
            execution_time_ms=execution_time
        )
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Tool execution failed: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/tools", tags=["Tools"])
async def list_tools():
    """List all available AutoJaga tools"""
    try:
        from jagabot.agent.tools.registry import ToolRegistry
        from jagabot.agent.tool_loader import register_default_tools
        
        registry = ToolRegistry()
        register_default_tools(
            registry,
            workspace=WORKSPACE,
            restrict_to_workspace=False,
            exec_config=None,
            brave_api_key=None,
            bus=None,
            subagents=None,
            cron_service=None,
        )
        
        tools = [
            {
                "name": tool.name,
                "description": tool.description,
                "parameters": tool.parameters
            }
            for tool in registry._tools.values()
        ]
        
        return {"status": "success", "tools": tools, "count": len(tools)}
        
    except Exception as e:
        logger.error(f"Failed to list tools: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/sessions", tags=["Sessions"])
async def list_sessions():
    """List active sessions"""
    return {
        "status": "success",
        "sessions": list(active_sessions.values()),
        "count": len(active_sessions)
    }


@app.delete("/sessions/{session_id}", tags=["Sessions"])
async def clear_session(session_id: str):
    """Clear a specific session"""
    if session_id in active_sessions:
        del active_sessions[session_id]
        return {"status": "success", "message": f"Session {session_id} cleared"}
    raise HTTPException(status_code=404, detail=f"Session {session_id} not found")


# ============================================================================
# Helper Functions
# ============================================================================

def _generate_fallback_blueprint(request: PlanRequest) -> str:
    """Generate basic blueprint when ResearchSkill unavailable"""
    return f"""# Experiment Blueprint

## 🎯 Objective
{request.prompt}

## 📊 Context
- Previous Results: {request.previous_results or "None"}
- Additional Context: {request.context or "None"}

## 🧠 Proposed Approach
1. Establish baseline
2. Identify improvement areas
3. Test optimization strategies
4. Validate results

## 📈 Expected Outcome
Improved performance over baseline

## 🔧 Implementation
- Use cross-validation
- Compare with baseline
- Document all changes
"""


def _generate_analysis_report(experiment_data, previous_results, evaluation) -> str:
    """Generate analysis report from evaluation"""
    return f"""# Experiment Analysis Report

## 📊 Results Summary
- Current Results: {experiment_data}
- Previous Results: {previous_results or "None"}

## 📈 Evaluation Metrics
- Score: {evaluation.score:.2%}
- Gap: {evaluation.gap:.2%}
- ROI: {evaluation.roi:.4f}

## 💡 Observations
The experiment showed measurable results compared to baseline.

## 🔍 Anomalies
{len(evaluation.anomalies)} anomalies detected

## 💬 Recommendations
{len(evaluation.improvements)} improvements suggested
"""


def _extract_improvement(experiment_data, previous_results) -> str:
    """Extract improvement percentage"""
    if not previous_results:
        return "Baseline experiment"
    
    # Try to find accuracy improvement
    curr_acc = experiment_data.get("accuracy")
    prev_acc = previous_results.get("accuracy")
    
    if curr_acc and prev_acc:
        try:
            improvement = float(curr_acc) - float(prev_acc)
            return f"{improvement:+.2%}"
        except (ValueError, TypeError):
            pass
    
    return "Improvement observed"


def _generate_next_prompt(experiment_data, previous_results, evaluation) -> str:
    """Generate next experiment prompt"""
    suggestions = []
    
    # Check for improvements
    if evaluation.improvements:
        for imp in evaluation.improvements:
            if imp.get("type") == "parallelize":
                suggestions.append("optimize execution")
            elif imp.get("type") == "cache_results":
                suggestions.append("add caching")
    
    # Default suggestions
    if not suggestions:
        suggestions = [
            "try ensemble methods",
            "add feature selection",
            "tune hyperparameters"
        ]
    
    return suggestions[0]


def _generate_fallback_analysis(request: AnalyzeRequest) -> str:
    """Generate basic analysis when EvaluationKernel unavailable"""
    return f"""# Analysis Report

## Results
- Current: {request.experiment_data}
- Previous: {request.previous_results or "None"}

## Observation
Results have been recorded and analyzed.

## Recommendation
Continue with next experiment iteration.
"""


# ============================================================================
# Main Entry Point
# ============================================================================



# ============================================================================
# AGENT BRIDGE - Lazy-start AgentLoop
# ============================================================================

_agent_bus: MessageBus = None
_agent_loop_task: asyncio.Task = None
_agent_instance: AgentLoop = None

async def get_or_start_agent() -> MessageBus:
    """Lazy-start AgentLoop."""
    global _agent_bus, _agent_loop_task, _agent_instance
    if _agent_bus is not None and _agent_loop_task and not _agent_loop_task.done():
        return _agent_bus
    logger.info("Starting Jagabot AgentLoop...")
    _agent_bus = MessageBus()
    config_path = Path.home() / ".jagabot" / "config.json"
    model = "dashscope/qwen-plus"
    if config_path.exists():
        with open(config_path) as f:
            config = json.load(f)
        model = config.get("agents", {}).get("defaults", {}).get("model", "dashscope/qwen-plus")
    logger.info(f"Using model: {model}")
    _agent_instance = AgentLoop(
        bus=_agent_bus,
        provider=LiteLLMProvider(
            api_key=config.get("providers", {}).get("dashscope", {}).get("apiKey", ""),
            api_base=config.get("providers", {}).get("dashscope", {}).get("apiBase"),
            default_model=model,
            provider_name="dashscope"
        ),
        workspace=Path("/root/.jagabot/workspace"),
        model=model,
        max_iterations=20,
    )
    _agent_loop_task = asyncio.create_task(_agent_instance.run())
    await asyncio.sleep(2)
    logger.info("✅ AgentLoop ready")
    return _agent_bus

@app.post("/execute")
async def execute_task(request: PlanRequest):
    """Full agent execution."""
    session_id = f"api_{int(asyncio.get_event_loop().time())}"
    try:
        logger.info(f"Executing: {request.prompt[:100]}...")
        bus = await get_or_start_agent()
        msg = InboundMessage(channel="api", chat_id=session_id, content=request.prompt, sender_id="copaw_cli")
        await bus.publish_inbound(msg)
        response = await asyncio.wait_for(bus.consume_outbound(chat_id=session_id), timeout=300)
        return {"status": "success", "session_id": session_id, "response": response.content, "tools_used": getattr(response, "tools_used", [])}
    except asyncio.TimeoutError:
        return {"status": "timeout", "session_id": session_id, "message": "Agent timeout"}
    except Exception as e:
        return {"status": "error", "message": str(e)}


def main():
    """Run the AutoJaga API server"""
    logger.info("Starting AutoJaga API server...")
    logger.info(f"Workspace: {WORKSPACE}")
    logger.info("API docs available at: http://localhost:8000/docs")
    
    uvicorn.run(
        app,
        host="0.0.0.0",
        port=8000,
        log_level="info"
    )


if __name__ == "__main__":
    main()
