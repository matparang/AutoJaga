# AutoJagaMAS Environment Configuration
# Copy to .env and fill in your API keys

# Cloud model (for RESEARCH/VERIFICATION/CALIBRATION/AUTONOMOUS profiles)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Local model (Ollama must be running on localhost:11434)
# No API key needed for local Ollama
# OLLAMA_API_KEY=ollama

# Optional: OpenRouter gateway (alternative to direct Anthropic)
# OPENROUTER_API_KEY=sk-or-your-key-here
