{
  "providers": {
    "ollama": {
      "api_base": "http://localhost:11434",
      "api_key": "ollama"
    }
  },
  "defaults": {
    "model": "ollama/deepseek-r1:1.5b",
    "temperature": 0.7,
    "memory_window": 20,
    "max_tokens": 512
  },
  "compression": {
    "enabled": true,
    "threshold": 15,
    "strategy": "sliding_window"
  }
}
