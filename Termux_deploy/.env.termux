# ============================================
# JagaChatbot Termux Environment
# No cloud API keys needed for local Ollama
# ============================================

# Local Ollama endpoint (do not change unless you changed Ollama's port)
OLLAMA_API_BASE=http://localhost:11434

# Optional cloud API fallback keys
# Leave blank to run fully offline
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Config file override — points to Termux-specific config
# This is the key that makes JagaChatbot use the local Ollama model
JAGACHATBOT_CONFIG=/data/data/com.termux/files/home/AutoJaga/Termux_deploy/config/termux_config.json
