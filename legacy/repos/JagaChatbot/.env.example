# JagaChatbot Environment Variables
# Copy to ~/.jagachatbot/.env and fill in your API keys

# =============================================================================
# LLM Provider API Keys (at least one required)
# =============================================================================

# OpenAI (GPT-4, GPT-4o, GPT-4o-mini)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (Claude 3.5, Claude 3)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# DeepSeek (DeepSeek-V3, DeepSeek-R1)
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Google Gemini
# GEMINI_API_KEY=your-gemini-key-here

# =============================================================================
# Optional: Gateway Providers (routes to multiple models)
# =============================================================================

# OpenRouter (access 200+ models with one key)
# OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# =============================================================================
# Optional: Model Selection
# =============================================================================

# Default model (uncomment to override)
# JAGACHATBOT_MODEL=openai/gpt-4o-mini
